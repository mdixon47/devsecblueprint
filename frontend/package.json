{
  "name": "devsec-blueprint-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "npm run generate && npm run generate-walkthroughs && npm run generate-walkthroughs-data && npm run copy-walkthrough-images && npm run generate-registry && next build",
    "start": "python -m http.server 3001 --directory out",
    "lint": "eslint",
    "test": "jest",
    "test:watch": "jest --watch",
    "generate": "tsx scripts/generate-pages.ts",
    "generate-walkthroughs": "tsx scripts/generate-walkthrough-pages.ts",
    "generate-walkthroughs-data": "tsx scripts/generate-walkthroughs-data.ts",
    "copy-walkthrough-images": "tsx scripts/copy-walkthrough-images.ts",
    "generate-registry": "tsx scripts/generate-content-registry.ts --output=dist/content-registry.json",
    "generate-registry:validate": "tsx scripts/generate-content-registry.ts --validate-only"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.709.0",
    "date-fns": "^4.1.0",
    "glob": "^11.0.0",
    "gray-matter": "^4.0.3",
    "marked": "^17.0.2",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "rehype-highlight": "^7.0.2",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/marked": "^5.0.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.24",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "fast-check": "^3.23.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
